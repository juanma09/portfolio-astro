---
interface Props {
  title: string;
  description: string;
  link: string;
  imageUrl: string;
  tags: string[]; // Added this line
}

const { title, description, link, imageUrl, tags } = Astro.props;
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="group block w-full cursor-pointer no-underline transition-transform duration-500 hover:scale-[1.01]"
>
  <div class="relative aspect-[16/10] overflow-hidden rounded-2xl bg-white/[0.03] mb-6 border border-white/5">
    <img
      src={imageUrl}
      alt={title}
      class="h-full w-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-in-out"
    />
    <div class="absolute inset-0 ring-1 ring-inset ring-white/10 group-hover:ring-emerald-500/30 transition-all duration-500 rounded-2xl"></div>
  </div>

  <div class="space-y-3">
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-[10px] uppercase tracking-widest font-bold px-2 py-1 rounded-md bg-white/[0.03] border border-white/5 text-zinc-500 group-hover:border-emerald-500/30 group-hover:text-emerald-400 transition-all duration-500">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex items-center justify-between">
      <h3 class="text-white text-xl font-semibold tracking-tight group-hover:text-emerald-400 transition-colors">
        {title}
      </h3>
    </div>
    <p class="text-zinc-500 text-sm leading-relaxed line-clamp-3 group-hover:text-zinc-300 transition-colors">
      {description}
    </p>
  </div>
</a>