---
import WakaTimeSummary from "./WakaTimeSummary";
// import { languageStats as fallbackStats } from "./language_stats";

// Fetch WakaTime Data
let languages = [];
let totalText = "";

try {
    const apiKey = import.meta.env.WAKATIME_API_KEY;
    if (!apiKey) throw new Error("WAKATIME_API_KEY is missing");

    const response = await fetch(
        "https://wakatime.com/api/v1/users/current/stats/last_7_days",
        {
            headers: {
                Authorization: `Basic ${btoa(apiKey + ":")}`,
            },
        },
    );

    const { data } = await response.json();

    // 1. Get all languages and identify if "Other" already exists
    const allItems = data.languages || [];
    allItems.sort((a: any, b: any) => b.total_seconds - a.total_seconds);

    // 2. Separate "Other" from real languages to find the true top 4
    const realLanguages = allItems
        .filter((l: any) => l.name !== "Other")
        .sort((a: any, b: any) => b.total_seconds - a.total_seconds);
    const existingOther = allItems.find((l: any) => l.name === "Other");

    // 3. Take Top 4 real languages
    const top4 = realLanguages.slice(0, 4);
    const rest = realLanguages.slice(4);

    // 4. Group all "rest" + "existingOther" into a single Other category
    languages = top4.map((l: any) => ({
        name: l.name,
        percent: l.percent,
        text: l.text,
    }));

    const othersToMerge = [...rest];
    if (existingOther) othersToMerge.push(existingOther);

    if (othersToMerge.length > 0) {
        const otherPercent = othersToMerge.reduce(
            (acc: number, curr: any) => acc + curr.percent,
            0,
        );
        const otherSeconds = othersToMerge.reduce(
            (acc: number, curr: any) => acc + curr.total_seconds,
            0,
        );

        // Simple time formatter
        const h = Math.floor(otherSeconds / 3600);
        const m = Math.floor((otherSeconds % 3600) / 60);
        const timeText =
            h > 0
                ? `${h} hr${h > 1 ? "s" : ""} ${m} min${m !== 1 ? "s" : ""}`
                : `${m} min${m !== 1 ? "s" : ""}`;

        languages.push({
            name: "Other",
            percent: Number(otherPercent.toFixed(2)),
            text: timeText,
        });
    }

    totalText =
        data.human_readable_total_including_other_language ||
        data.human_readable_total ||
        "";
} catch (e) {
    console.error("WakaTime fetch failed, using fallback:", e);
    // Fallback logic
    // const allLangs = [...fallbackStats.languages].sort((a: any, b: any) => b.total_seconds - a.total_seconds);
    // languages = allLangs.slice(0, 4).map((l: any) => ({ name: l.name, percent: l.percent, text: l.text }));

    // const rest = allLangs.slice(4);
    // if (rest.length > 0) {
    //     const otherPercent = rest.reduce((acc: number, curr: any) => acc + curr.percent, 0);
    //     const otherSeconds = rest.reduce((acc: number, curr: any) => acc + curr.total_seconds, 0);
    //     const h = Math.floor(otherSeconds / 3600);
    //     const m = Math.floor((otherSeconds % 3600) / 60);
    //     languages.push({
    //         name: 'Other',
    //         percent: Number(otherPercent.toFixed(2)),
    //         text: h > 0 ? `${h} hrs ${m} mins` : `${m} mins`
    //     });
    // }
    // totalText = fallbackStats.grand_total.text;
}
---

<WakaTimeSummary client:load languages={languages} totalText={totalText} />
