---
import ExperienceGroup from "./ExperienceGroup.astro";

const workHistory = [
  {
    company: "International Games System",
    role: "Research And Development Intern",
    location: "Taipei, Taiwan",
    period: "July 2025 — December 2025",
    description: [
      "Architected high-traffic reward systems and scalable APIs with a focus on data integrity and real-time processing.",
      "Optimized game mechanics for 30+ titles through probability modeling, driving a 10% boost in user engagement.",
    ],
    technologies: ["Python", "MongoDB", "Redis"],
  },
  {
    company: "AgilTech",
    role: "Junior Software Developer",
    location: "Asunción, Paraguay (Remote)",
    period: "December 2023 — February 2024",
    description: [
      "Contributed to the development of a new internal tool for the company.",
    ],
    technologies: ["Next.js", "Tailwind CSS"],
  },
];

const studyHistory = [
  {
    company: "National Taiwan University of Science and Technology",
    role: "Exchange Program for Information Engineering",
    location: "Taipei, Taiwan",
    period: "February 2024 - December 2025",
    techologies: [],
  },
  {
    company: "Universidad Politécnica Taiwán-Paraguay",
    role: "Bachelor’s Degree in Information Engineering",
    location: "Paraguay - Taiwan",
    period: "February 2022 - December 2025",
  },
  {
    company: "Colegio Campoalto",
    role: "High School Diploma Dec 2021",
    location: "Asunción, Paraguay",
    period: "December 2021",
  },
];
---

<section id="experience" class="w-full">
  <div class="mb-10 space-y-4">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-white">
      Experience
    </h2>
    <div class="h-1.5 w-15 bg-emerald-500 rounded-full"></div>
  </div>
  <div class="flex flex-col gap-12">
    <!-- Tab Switcher -->
    <div
      class="flex gap-8 border-b border-zinc-800/50 relative"
      id="tabs-container"
    >
      <button
        id="work-tab"
        class="pb-4 px-2 text-sm font-mono uppercase tracking-widest transition-all duration-300 text-zinc-100"
      >
        Work
      </button>
      <button
        id="study-tab"
        class="pb-4 px-2 text-sm font-mono uppercase tracking-widest transition-all duration-300 text-zinc-500 hover:text-zinc-300"
      >
        Study
      </button>
      <!-- Dynamic Animated Bar -->
      <div
        id="tab-indicator"
        class="absolute bottom-0 h-0.5 bg-emerald-500 transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)]"
        style="left: 0; width: 0;"
      >
      </div>
    </div>

    <!-- Content Containers -->
    <div id="work-content" class="block animate-in fade-in duration-500">
      <ExperienceGroup title="Professional Experience" items={workHistory} />
    </div>

    <div id="study-content" class="hidden animate-in fade-in duration-500">
      <ExperienceGroup title="Educational Background" items={studyHistory} />
    </div>
  </div>
</section>

<script>
  const workTab = document.getElementById("work-tab") as HTMLButtonElement;
  const studyTab = document.getElementById("study-tab") as HTMLButtonElement;
  const workContent = document.getElementById("work-content");
  const studyContent = document.getElementById("study-content");
  const indicator = document.getElementById("tab-indicator");

  function switchTab(activeId: "work" | "study") {
    if (!workTab || !studyTab || !workContent || !studyContent || !indicator)
      return;

    const activeTab = activeId === "work" ? workTab : studyTab;
    const inactiveTab = activeId === "work" ? studyTab : workTab;

    // Update Text Styles
    activeTab.classList.add("text-zinc-100");
    activeTab.classList.remove("text-zinc-500");
    inactiveTab.classList.remove("text-zinc-100");
    inactiveTab.classList.add("text-zinc-500");

    // Move Indicator
    indicator.style.left = `${activeTab.offsetLeft}px`;
    indicator.style.width = `${activeTab.offsetWidth}px`;

    // Toggle Content
    if (activeId === "work") {
      workContent.classList.remove("hidden");
      workContent.classList.add("block");
      studyContent.classList.add("hidden");
      studyContent.classList.remove("block");
    } else {
      studyContent.classList.remove("hidden");
      studyContent.classList.add("block");
      workContent.classList.add("hidden");
      workContent.classList.remove("block");
    }
  }

  workTab?.addEventListener("click", () => switchTab("work"));
  studyTab?.addEventListener("click", () => switchTab("study"));

  // Initial position
  window.addEventListener("load", () => switchTab("work"));
  // Also run immediately to avoid jump if possible
  switchTab("work");
</script>
